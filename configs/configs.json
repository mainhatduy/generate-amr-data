{
  "vllm_config": {
    "model": "Qwen/Qwen3.6-35B-A3B-FP8",
    "tensor_parallel_size": 1,
    "gpu_memory_utilization": 0.85,

    "max_model_len": 4096,
    "max_tokens": 1024,
    "temperature": 1.0,
    "top_p": 0.95,
    "top_k": 20,
    "min_p": 0.0,
    "presence_penalty": 1.5,
    "repetition_penalty": 1.0
  },
  "data_config": {
    "dataset": "viamr-project/reasoning-frame-hint",
    "split": "train",
    "sentence_field": "sentence",
    "amr_field": "amr"
  },
  "generate_systhetic_data": {
    "response_for_each_sample": 4
  },
  "env": {
    "CUDA_VISIBLE_DEVICES": "1"
  }
}