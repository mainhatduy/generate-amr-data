{
  "deepseek_config": {
    "model": "deepseek-v4-flash",
    "max_tokens": 16384,
    "thinking": {
      "type": "disabled"
    },
    "reasoning_effort": "medium"
  },
  "data_config": {
    "dataset": "viamr-project/reasoning-frame-hint",
    "split": "train",
    "sentence_field": "sentence",
    "amr_field": "amr"
  },
  "generate_synthetic_data": {
    "batch_size": 32,
    "response_for_each_sample": 1
  },
  "env": {
    "CUDA_VISIBLE_DEVICES": "0"
  }
}
